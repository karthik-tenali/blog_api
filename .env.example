POSTGRES_USER=uname
POSTGRES_PASSWORD=password
POSTGRES_DB=databasename

DATABASE_URL=postgresql+asyncpg://uname:password@localhost:5432/databasename
SECRET_KEY=your-super-secret-key-change-this-in-prod-min32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
REDIS_URL=redis://localhost:6379
DEBUG=True
LOG_LEVEL=INFO
ALLOWED_ORIGINS=["http://localhost:3000"]
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800